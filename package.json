{
  "name": "codeaudit-workspace",
  "version": "0.1.3",
  "private": true,
  "description": "Skills-driven MCP system for project detection, audits, documentation evidence, and PR planning.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm --filter @priyanshuchawda/codeaudit build",
    "dev": "pnpm --filter @priyanshuchawda/codeaudit dev",
    "dev:http": "pnpm --filter @priyanshuchawda/codeaudit dev:http",
    "start:http": "pnpm --filter @priyanshuchawda/codeaudit start:http",
    "typecheck": "pnpm --filter @priyanshuchawda/codeaudit typecheck",
    "test": "pnpm --filter @priyanshuchawda/codeaudit test",
    "lint": "pnpm --filter @priyanshuchawda/codeaudit lint",
    "format": "prettier --write .",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
