{
  "name": "reposentinel",
  "version": "0.1.0",
  "private": true,
  "description": "Skills-driven MCP system for project detection, audits, documentation evidence, and PR planning.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm --filter reposentinel-mcp build",
    "dev": "pnpm --filter reposentinel-mcp dev",
    "dev:http": "pnpm --filter reposentinel-mcp dev:http",
    "start:http": "pnpm --filter reposentinel-mcp start:http",
    "typecheck": "pnpm --filter reposentinel-mcp typecheck",
    "test": "pnpm --filter reposentinel-mcp test",
    "lint": "pnpm --filter reposentinel-mcp lint",
    "format": "prettier --write .",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
