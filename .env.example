# RepoSentinel MCP runtime
REPOSENTINEL_TRANSPORT=stdio
REPOSENTINEL_HOST=127.0.0.1
REPOSENTINEL_PORT=3000
REPOSENTINEL_PUBLIC_BASE_URL=http://127.0.0.1:3000

# Set this for HTTP deployments. Keep secret values out of git.
REPOSENTINEL_REQUIRE_API_KEY=false
REPOSENTINEL_API_KEY=
REPOSENTINEL_ALLOWED_ORIGINS=*
