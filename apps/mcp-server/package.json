{
  "name": "@reposentinel/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "RepoSentinel read-only MCP server for project audits and skill routing.",
  "type": "module",
  "bin": {
    "reposentinel-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --clean",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=20"
  }
}
